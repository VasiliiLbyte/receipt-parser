# Конфигурация API ключей для receipt-parser
# Скопируйте этот файл в .env и заполните реальными значениями

# === ОБЯЗАТЕЛЬНЫЕ НАСТРОЙКИ ===

# OpenAI API ключ (fallback GPT-4o при PIPELINE_VARIANT=c и ENABLE_FALLBACK=true)
# https://platform.openai.com/api-keys
# Для PIPELINE_VARIANT=legacy — основной Vision-провайдер
OPENAI_API_KEY=sk-your-actual-openai-api-key-here

# === ОПЦИОНАЛЬНЫЕ НАСТРОЙКИ ===

# DeepSeek API ключ для текстового анализа
# Получить можно на https://platform.deepseek.com/api_keys
# Требуется только если планируете использовать DeepSeek API
DEEPSEEK_API_KEY=your-actual-deepseek-api-key-here

# OpenRouter API ключ (primary Vision в variant C + верификация имён)
# https://openrouter.ai/keys
# Для PIPELINE_VARIANT=c и PRIMARY_PROVIDER=openrouter ключ обязателен (или задайте primary=openai)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# === PIPELINE (variant C: OpenRouter → при сбое OpenAI) ===
# c = primary OpenRouter (Gemini Flash Lite) + опциональный fallback GPT-4o
# legacy = один проход OpenAI + опциональный verify OpenRouter (старое поведение)
PIPELINE_VARIANT=c
PRIMARY_PROVIDER=openrouter
PRIMARY_MODEL=google/gemini-3.1-flash-lite-preview
FALLBACK_PROVIDER=openai
FALLBACK_MODEL=gpt-4o
ENABLE_FALLBACK=true
ENABLE_QUALITY_GATES=true

# === НАСТРОЙКИ ПРИЛОЖЕНИЯ ===

# Максимальный размер файла в МБ
# OpenAI ограничивает 20 МБ для Vision API
MAX_FILE_SIZE_MB=20

# Настройки повторных попыток при ошибках API
MAX_RETRIES=3
RETRY_DELAY_SECONDS=5

# Настройки вывода
# Доступные форматы: excel, csv, json
OUTPUT_FORMAT=excel

# Имя выходного файла (без пути)
OUTPUT_FILENAME=receipts.xlsx

# === РАСШИРЕННЫЕ НАСТРОЙКИ ===

# Уровень детализации логов
# Доступные уровни: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Сохранять ли промежуточные файлы (OCR текст, обработанные изображения)
SAVE_INTERMEDIATE_FILES=false

# Путь для сохранения промежуточных файлов
INTERMEDIATE_FILES_PATH=./temp

# Таймаут запросов к API в секундах
API_TIMEOUT=60

# === ПРИМЕЧАНИЯ ===
# 1. Не коммитьте файл .env в репозиторий (он в .gitignore)
# 2. Для безопасности храните API ключи в секретах
# 3. Для тестирования используйте тестовые ключи или бесплатные квоты
# 4. После normalize/validate pipeline дополнительно прогоняет Pydantic (src/schemas.py);
#    при ошибке схемы результат всё равно собирается из предыдущего шага (без обрезания позиций)