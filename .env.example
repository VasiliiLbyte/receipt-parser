# Конфигурация API ключей для receipt-parser
# Скопируйте этот файл в .env и заполните реальными значениями

# === ОБЯЗАТЕЛЬНЫЕ НАСТРОЙКИ ===

# OpenRouter API ключ — используется для извлечения (Pass 1) и верификации (Pass 2)
# Получить можно на https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Этап 1 (извлечение): gemini-2.0-flash-001 — быстрый, хорошо читает русские чеки
# Этап 2 (верификация): gemini-2.5-flash-preview — аналитическая проверка и исправление
# Избегай openai/* и azure/* — заблокированы в РФ даже через OpenRouter
OPENROUTER_EXTRACT_MODEL=google/gemini-2.0-flash-001
OPENROUTER_VERIFY_MODEL=google/gemini-2.5-flash-preview

# === ОПЦИОНАЛЬНЫЕ НАСТРОЙКИ ===

# OpenAI API ключ (опционально, не используется в основном потоке)
# Если хотите вызывать OpenAI напрямую — укажите ключ
OPENAI_API_KEY=

# DeepSeek API ключ для текстового анализа
# Получить можно на https://platform.deepseek.com/api_keys
# Требуется только если планируете использовать DeepSeek API
DEEPSEEK_API_KEY=your-actual-deepseek-api-key-here

# === НАСТРОЙКИ ПРИЛОЖЕНИЯ ===

# Путь к SQLite базе данных для хранения сессий пользователей
# При запуске в Docker рекомендуется монтировать как volume
DB_PATH=./data/sessions.db

# Максимальный размер файла в МБ
# OpenAI ограничивает 20 МБ для Vision API
MAX_FILE_SIZE_MB=20

# Настройки повторных попыток при ошибках API
MAX_RETRIES=3
RETRY_DELAY_SECONDS=5

# Настройки вывода
# Доступные форматы: excel, csv, json
OUTPUT_FORMAT=excel

# Имя выходного файла (без пути)
OUTPUT_FILENAME=receipts.xlsx

# Версия схемы CommerceML (не менять без необходимости)
COMMERCEML_VERSION=2.09

# === РАСШИРЕННЫЕ НАСТРОЙКИ ===

# Уровень детализации логов
# Доступные уровни: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Сохранять ли промежуточные файлы (OCR текст, обработанные изображения)
SAVE_INTERMEDIATE_FILES=false

# Путь для сохранения промежуточных файлов
INTERMEDIATE_FILES_PATH=./temp

# Таймаут запросов к API в секундах
API_TIMEOUT=60

# Минимальная видимость чека (0.0-1.0), по умолчанию 70%
# Чеки, перекрытые более чем на 30%, будут отклонены
MIN_RECEIPT_VISIBLE_RATIO=0.70

# === TELEGRAM / MAX БОТЫ ===

# Токен Telegram-бота (обязателен для запуска TG-бота)
# Получить у @BotFather: https://t.me/BotFather
TG_TOKEN=

# Токен MAX-бота (опционально, для будущей интеграции)
MAX_TOKEN=

# Адрес FastAPI backend (по умолчанию http://localhost:8000)
BACKEND_BASE_URL=http://localhost:8000

# API ключ для доступа к /api/v1/* (оставить пустым для dev-режима без аутентификации)
API_KEY=

# Вебхук 1С: URL HTTP-сервиса в 1С для автоматической отправки чеков
# Оставить пустым чтобы отключить
WEBHOOK_1C_URL=
# Секрет для верификации вебхука на стороне 1С
WEBHOOK_1C_SECRET=

# Директория для файлового обмена с 1С
# 1С может мониторить эту папку через регламентное задание
EXCHANGE_DIR=./exchange/

# Прокси для Telegram API (api.telegram.org заблокирован у многих провайдеров в РФ)
# Если у вас есть VPN на уровне системы — оставьте пустым.
# Примеры:
#   http://user:pass@proxy.example.com:8080
#   socks5://user:pass@proxy.example.com:1080
TG_PROXY=

# === ПРИМЕЧАНИЯ ===
# 1. Не коммитьте файл .env в репозиторий (он в .gitignore)
# 2. Для безопасности храните API ключи в секретах
# 3. Для тестирования используйте тестовые ключи или бесплатные квоты
# 4. После normalize/validate pipeline дополнительно прогоняет Pydantic (src/schemas.py);
#    при ошибке схемы результат всё равно собирается из предыдущего шага (без обрезания позиций)