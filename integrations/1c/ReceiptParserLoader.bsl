// ==========================================
// ВНЕШНЯЯ ОБРАБОТКА: Receipt Parser Loader
// Версия: 2.0
// Назначение: загрузка чеков из Receipt Parser API в 1С
// Конфигурация: требует АвансовыйОтчет, Контрагенты, Номенклатура, СтавкиНДС
// ==========================================

// --- РЕКВИЗИТЫ ФОРМЫ ---
// СерверURL     (Строка)  — по умолчанию "http://localhost:8001"
// APIКлюч       (Строка)  — оставить пустым если API_KEY не задан
// ПользовательID (Число)  — telegram user_id, по умолчанию 769499969
// ДатаС         (Дата)    — необязательная фильтрация от даты
// ДатаПо        (Дата)    — необязательная фильтрация до даты
// ПолеСообщений (Строка)  — лог загрузки (многострочное текстовое поле)

// ============================================================
// КНОПКА: Загрузить
// ============================================================

&НаКлиенте
Процедура КнопкаЗагрузитьНажатие(Кнопка)
	ОчиститьСообщения();
	ЗагрузитьЧеки();
КонецПроцедуры

// ============================================================
// КНОПКА: Очистить (удалить все созданные АвансовыеОтчеты — для повторного тестирования)
// ============================================================

&НаКлиенте
Процедура КнопкаОчиститьНажатие(Кнопка)
	Если Вопрос("Удалить ВСЕ документы АвансовыйОтчет? Действие необратимо.", РежимДиалогаВопрос.ДаНет) = КодВозвратаДиалога.Да Тогда
		УдалитьВсеАвансовыеОтчеты();
	КонецЕсли;
КонецПроцедуры

// ============================================================
// ОСНОВНАЯ ПРОЦЕДУРА ЗАГРУЗКИ
// ============================================================

&НаСервере
Процедура ЗагрузитьЧеки()
	
	СерверURL = РеквизитФормыВЗначение("СерверURL");
	APIКлюч   = РеквизитФормыВЗначение("APIКлюч");
	UserID    = РеквизитФормыВЗначение("ПользовательID");
	ДатаОт    = РеквизитФормыВЗначение("ДатаС");
	ДатаДо    = РеквизитФормыВЗначение("ДатаПо");
	
	Если ПустаяСтрока(СерверURL) Тогда
		ДобавитьВЛог("ОШИБКА: Не заполнен параметр СерверURL.");
		Возврат;
	КонецЕсли;
	
	Если UserID = Неопределено ИЛИ UserID = 0 Тогда
		ДобавитьВЛог("ОШИБКА: Не заполнен параметр ПользовательID.");
		Возврат;
	КонецЕсли;
	
	ДобавитьВЛог("Подключение к " + СерверURL + "...");
	
	Попытка
		АдресСервера = СтрЗаменить(СерверURL, "http://", "");
		АдресСервера = СтрЗаменить(АдресСервера, "https://", "");
		
		// Определить порт
		Порт = 80;
		Если СтрНайти(АдресСервера, ":") > 0 Тогда
			Части = СтрРазделить(АдресСервера, ":");
			АдресСервера = Части[0];
			Порт = Число(Части[1]);
		КонецЕсли;
		
		Соединение = Новый HTTPСоединение(АдресСервера, Порт);
		Заголовки = Новый Соответствие;
		Заголовки.Вставить("Accept", "application/json");
		Если НЕ ПустаяСтрока(APIКлюч) Тогда
			Заголовки.Вставить("X-API-Key", APIКлюч);
		КонецЕсли;
		
		// Формирование URL с параметрами
		Путь = "/api/v1/receipts?user_id=" + Строка(UserID) + "&limit=500&offset=0";
		Если ЗначениеЗаполнено(ДатаОт) Тогда
			Путь = Путь + "&date_from=" + Формат(ДатаОт, "ДФ=yyyy-MM-dd");
		КонецЕсли;
		Если ЗначениеЗаполнено(ДатаДо) Тогда
			Путь = Путь + "&date_to=" + Формат(ДатаДо, "ДФ=yyyy-MM-dd");
		КонецЕсли;
		
		Запрос = Новый HTTPЗапрос(Путь, Заголовки);
		Ответ = Соединение.Получить(Запрос);
		
		Если Ответ.КодСостояния <> 200 Тогда
			ДобавитьВЛог("ОШИБКА API: HTTP " + Строка(Ответ.КодСостояния));
			Возврат;
		КонецЕсли;
		
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(Ответ.ПолучитьТелоКакСтроку());
		Данные = ПрочитатьJSON(ЧтениеJSON);
		
		Если ТипЗнч(Данные) <> Тип("Структура") Тогда
			ДобавитьВЛог("ОШИБКА: Некорректный формат ответа API.");
			Возврат;
		КонецЕсли;
		
		Чеки = Данные.receipts;
		Если Чеки = Неопределено Тогда
			ДобавитьВЛог("ОШИБКА: В ответе API нет поля receipts.");
			Возврат;
		КонецЕсли;
		
		ДобавитьВЛог("Получено чеков: " + Строка(Чеки.Количество()));
		
		СчетчикЗагружено = 0;
		Для Каждого Чек Из Чеки Цикл
			Результат = ЗагрузитьОдинЧек(Чек);
			Если Результат <> "" Тогда
				ДобавитьВЛог(Результат);
				СчетчикЗагружено = СчетчикЗагружено + 1;
			КонецЕсли;
		КонецЦикла;
		
		ДобавитьВЛог("Готово. Загружено документов: " + Строка(СчетчикЗагружено));
		
	Исключение
		ДобавитьВЛог("ОШИБКА загрузки: " + ОписаниеОшибки());
	КонецПопытки;
	
КонецПроцедуры

// ============================================================
// ЗАГРУЗКА ОДНОГО ЧЕКА → создание АвансовыйОтчет
// ============================================================

&НаСервере
Функция ЗагрузитьОдинЧек(Чек)
	
	Попытка
		Если НЕ Метаданные.Документы.Содержит(Метаданные.Документы.АвансовыйОтчет) Тогда
			Возврат "ОШИБКА: В конфигурации отсутствует документ АвансовыйОтчет.";
		КонецЕсли;
		
		ДокументОбъект = Документы.АвансовыйОтчет.СоздатьДокумент();
		
		// Дата документа
		ДокументОбъект.Дата = ТекущаяДата();
		
		// НомерЧека из поля "id"
		ЧекID = "";
		Если Чек.id <> Неопределено Тогда
			ЧекID = Строка(Чек.id);
		КонецЕсли;
		ДокументОбъект.НомерЧека = ЧекID;
		
		// ДатаЧека из поля "date"
		ДатаЧекаСтрока = "";
		Если Чек.date <> Неопределено И НЕ ПустаяСтрока(Чек.date) Тогда
			ДатаЧекаСтрока = Строка(Чек.date);
			Попытка
				// Формат ISO: "2024-10-19" или "2024-10-19T10:32:00"
				ДатаЧекаСтрока = СтрЗаменить(ДатаЧекаСтрока, "T", " ");
				Части = СтрРазделить(ДатаЧекаСтрока, "-");
				Если Части.Количество() >= 3 Тогда
					ДокументОбъект.ДатаЧека = Дата(Число(Части[0]), Число(Части[1]), Число(СтрРазделить(Части[2], " ")[0]));
				КонецЕсли;
			Исключение
				// Игнорировать ошибку парсинга даты
			КонецПопытки;
		КонецЕсли;
		
		// ИНН и наименование организации
		ИНН = "";
		Если Чек.inn <> Неопределено Тогда
			ИНН = Строка(Чек.inn);
		КонецЕсли;
		
		НаименованиеОрг = "";
		Если Чек.organization <> Неопределено Тогда
			НаименованиеОрг = Строка(Чек.organization);
		КонецЕсли;
		
		СтрокаКонтрагент = "";
		Если ЗначениеЗаполнено(ИНН) Тогда
			Контрагент = НайтиКонтрагентаПоИНН(ИНН, НаименованиеОрг);
			ДокументОбъект.Контрагент = Контрагент;
			СтрокаКонтрагент = НаименованиеОрг + " (ИНН " + ИНН + ")";
		ИначеЕсли ЗначениеЗаполнено(НаименованиеОрг) Тогда
			Контрагент = НайтиКонтрагентаПоНаим(НаименованиеОрг);
			ДокументОбъект.Контрагент = Контрагент;
			СтрокаКонтрагент = НаименованиеОрг;
		КонецЕсли;
		
		// Сумма документа
		Если Чек.total <> Неопределено Тогда
			ДокументОбъект.СуммаДокумента = Чек.total;
		КонецЕсли;
		
		// Сумма НДС (из шапки если есть)
		Если Чек.vat_total <> Неопределено Тогда
			ДокументОбъект.СуммаНДС = Чек.vat_total;
		КонецЕсли;
		
		// Табличная часть Товары
		Если Чек.items <> Неопределено Тогда
			Для Каждого Товар Из Чек.items Цикл
				СтрокаТЧ = ДокументОбъект.Товары.Добавить();
				
				НаимТовара = "";
				Если Товар.name <> Неопределено Тогда
					НаимТовара = Строка(Товар.name);
				КонецЕсли;
				Если ПустаяСтрока(НаимТовара) Тогда
					НаимТовара = "Товар без названия";
				КонецЕсли;
				
				СтрокаТЧ.Номенклатура = НайтиИлиСоздатьНоменклатуру(НаимТовара);
				СтрокаТЧ.Количество  = ?(Товар.quantity   = Неопределено, 1, Товар.quantity);
				СтрокаТЧ.Цена        = ?(Товар.price      = Неопределено, 0, Товар.price);
				СтрокаТЧ.Сумма       = ?(Товар.amount     = Неопределено, 0, Товар.amount);
				СтрокаТЧ.СуммаНДС    = ?(Товар.vat_amount = Неопределено, 0, Товар.vat_amount);
				
				СтавкаСтрока = "";
				Если Товар.vat_rate <> Неопределено Тогда
					СтавкаСтрока = Строка(Товар.vat_rate);
				КонецЕсли;
				СтрокаТЧ.СтавкаНДС = СтавкаНДСВСтрочку(СтавкаСтрока);
			КонецЦикла;
		КонецЕсли;
		
		ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
		
		СуммаРуб = Формат(ДокументОбъект.СуммаДокумента, "ЧДЦ=2; ЧРД=.");
		Возврат "Создан АвансовыйОтчет №" + ДокументОбъект.Номер
		      + " от " + Формат(ДокументОбъект.ДатаЧека, "ДФ=dd.MM.yyyy")
		      + " | " + СтрокаКонтрагент
		      + " | " + СуммаРуб + " руб.";
		
	Исключение
		Возврат "ОШИБКА загрузки чека #" + ?(Чек.id = Неопределено, "?", Строка(Чек.id)) + ": " + ОписаниеОшибки();
	КонецПопытки;
	
КонецФункции

// ============================================================
// ПОИСК / СОЗДАНИЕ КОНТРАГЕНТА
// ============================================================

&НаСервере
Функция НайтиКонтрагентаПоИНН(ИНН, Наименование)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|    Контрагенты.Ссылка
		|ИЗ
		|    Справочник.Контрагенты КАК Контрагенты
		|ГДЕ
		|    Контрагенты.ИНН = &ИНН";
	Запрос.УстановитьПараметр("ИНН", ИНН);
	Результат = Запрос.Выполнить().Выбрать();
	
	Если Результат.Следующий() Тогда
		Возврат Результат.Ссылка;
	КонецЕсли;
	
	// Создать нового контрагента
	НовыйКонтрагент = Справочники.Контрагенты.СоздатьЭлемент();
	НовыйКонтрагент.Наименование = ?(ПустаяСтрока(Наименование), "Контрагент " + ИНН, Наименование);
	НовыйКонтрагент.ИНН = ИНН;
	НовыйКонтрагент.Записать();
	ДобавитьВЛог("Создан контрагент: " + НовыйКонтрагент.Наименование + " (ИНН " + ИНН + ")");
	Возврат НовыйКонтрагент.Ссылка;
	
КонецФункции

&НаСервере
Функция НайтиКонтрагентаПоНаим(Наименование)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|    Контрагенты.Ссылка
		|ИЗ
		|    Справочник.Контрагенты КАК Контрагенты
		|ГДЕ
		|    Контрагенты.Наименование = &Наим";
	Запрос.УстановитьПараметр("Наим", Наименование);
	Результат = Запрос.Выполнить().Выбрать();
	
	Если Результат.Следующий() Тогда
		Возврат Результат.Ссылка;
	КонецЕсли;
	
	НовыйКонтрагент = Справочники.Контрагенты.СоздатьЭлемент();
	НовыйКонтрагент.Наименование = Наименование;
	НовыйКонтрагент.Записать();
	ДобавитьВЛог("Создан контрагент (без ИНН): " + Наименование);
	Возврат НовыйКонтрагент.Ссылка;
	
КонецФункции

// ============================================================
// ПОИСК / СОЗДАНИЕ НОМЕНКЛАТУРЫ
// ============================================================

&НаСервере
Функция НайтиИлиСоздатьНоменклатуру(Наименование)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|    Номенклатура.Ссылка
		|ИЗ
		|    Справочник.Номенклатура КАК Номенклатура
		|ГДЕ
		|    Номенклатура.Наименование = &Наим";
	Запрос.УстановитьПараметр("Наим", Наименование);
	Результат = Запрос.Выполнить().Выбрать();
	
	Если Результат.Следующий() Тогда
		Возврат Результат.Ссылка;
	КонецЕсли;
	
	НоваяНоменкл = Справочники.Номенклатура.СоздатьЭлемент();
	НоваяНоменкл.Наименование = Наименование;
	НоваяНоменкл.Записать();
	Возврат НоваяНоменкл.Ссылка;
	
КонецФункции

// ============================================================
// СТАВКА НДС
// ============================================================

&НаСервере
Функция СтавкаНДСВСтрочку(СтавкаСтрока)
	// Возвращает строку — совместимо с реквизитом типа Строка(10)
	Если СтавкаСтрока = "20%" ИЛИ СтавкаСтрока = "20" ИЛИ СтавкаСтрока = "НДС20" Тогда
		Возврат "20%";
	ИначеЕсли СтавкаСтрока = "10%" ИЛИ СтавкаСтрока = "10" ИЛИ СтавкаСтрока = "НДС10" Тогда
		Возврат "10%";
	ИначеЕсли СтавкаСтрока = "0%" ИЛИ СтавкаСтрока = "0" ИЛИ СтавкаСтрока = "НДС0" Тогда
		Возврат "0%";
	Иначе
		Возврат "Без НДС";
	КонецЕсли;
КонецФункции

// ============================================================
// ОЧИСТКА: удалить все АвансовыеОтчеты
// ============================================================

&НаСервере
Процедура УдалитьВсеАвансовыеОтчеты()
	
	Попытка
		Запрос = Новый Запрос;
		Запрос.Текст =
			"ВЫБРАТЬ
			|    АвансовыйОтчет.Ссылка
			|ИЗ
			|    Документ.АвансовыйОтчет КАК АвансовыйОтчет";
		Результат = Запрос.Выполнить().Выбрать();
		
		Счетчик = 0;
		Пока Результат.Следующий() Цикл
			ДокОбъект = Результат.Ссылка.ПолучитьОбъект();
			ДокОбъект.УстановитьПометкуУдаления(Истина);
			Счетчик = Счетчик + 1;
		КонецЦикла;
		
		ДобавитьВЛог("Помечено на удаление документов: " + Строка(Счетчик));
		ДобавитьВЛог("Запустите Администрирование → Удаление помеченных объектов для окончательного удаления.");
		
	Исключение
		ДобавитьВЛог("ОШИБКА при очистке: " + ОписаниеОшибки());
	КонецПопытки;
	
КонецПроцедуры

// ============================================================
// ЛОГ
// ============================================================

&НаСервере
Процедура ДобавитьВЛог(Текст)
	Время = Формат(ТекущаяДата(), "ДФ=HH:mm");
	СтрокаЛога = "[" + Время + "] " + Текст;
	Сообщить(СтрокаЛога);
	// Также добавляем в реквизит формы ПолеСообщений
	ТекущийЛог = РеквизитФормыВЗначение("ПолеСообщений");
	ЗначениеВРеквизитФормы(Текущий Лог + Символы.ПС + СтрокаЛога, "ПолеСообщений");
КонецПроцедуры
