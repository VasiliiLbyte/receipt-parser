// ==========================================
// ВНЕШНЯЯ ОБРАБОТКА: Receipt Parser Loader
// Версия: 1.0
// Назначение: загрузка чеков из Receipt Parser API в 1С
// ==========================================

// --- ПАРАМЕТРЫ ПОДКЛЮЧЕНИЯ ---
// Задать перед использованием:
// СерверURL = "http://ваш-сервер:8000"
// APIКлюч   = ""  // оставить пустым если API_KEY не задан
// ПользовательID = 1  // telegram user_id

&НаКлиенте
Процедура КнопкаЗагрузитьНажатие(Кнопка)
	ЗагрузитьЧеки();
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьЧеки()
	
	СерверURL = РеквизитФормыВЗначение("СерверURL");
	APIКлюч = РеквизитФормыВЗначение("APIКлюч");
	UserID = РеквизитФормыВЗначение("ПользовательID");
	
	Если ПустаяСтрока(СерверURL) Тогда
		Сообщить("Не заполнен параметр СерверURL.");
		Возврат;
	КонецЕсли;
	
	Если UserID = Неопределено Тогда
		Сообщить("Не заполнен параметр ПользовательID.");
		Возврат;
	КонецЕсли;
	
	Попытка
		АдресСервера = СтрЗаменить(СерверURL, "http://", "");
		АдресСервера = СтрЗаменить(АдресСервера, "https://", "");
		
		Соединение = Новый HTTPСоединение(АдресСервера);
		Заголовки = Новый Соответствие;
		Заголовки.Вставить("Accept", "application/json");
		Если НЕ ПустаяСтрока(APIКлюч) Тогда
			Заголовки.Вставить("X-API-Key", APIКлюч);
		КонецЕсли;
		
		Путь = "/api/v1/receipts?user_id=" + Строка(UserID) + "&limit=500&offset=0";
		Запрос = Новый HTTPЗапрос(Путь, Заголовки);
		Ответ = Соединение.Получить(Запрос);
		
		Если Ответ.КодСостояния <> 200 Тогда
			Сообщить("Ошибка API: " + Строка(Ответ.КодСостояния));
			Возврат;
		КонецЕсли;
		
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(Ответ.ПолучитьТелоКакСтроку());
		Данные = ПрочитатьJSON(ЧтениеJSON);
		
		Если ТипЗнч(Данные) <> Тип("Структура") Тогда
			Сообщить("Некорректный формат ответа API.");
			Возврат;
		КонецЕсли;
		
		Чеки = Данные.receipts;
		Если Чеки = Неопределено Тогда
			Сообщить("В ответе API нет поля receipts.");
			Возврат;
		КонецЕсли;
		
		СчетчикЗагружено = 0;
		Для Каждого Чек Из Чеки Цикл
			Если ЗагрузитьОдинЧек(Чек) Тогда
				СчетчикЗагружено = СчетчикЗагружено + 1;
			КонецЕсли;
		КонецЦикла;
		
		Сообщить("Загружено чеков: " + Строка(СчетчикЗагружено));
		
	Исключение
		Сообщить("Ошибка загрузки чеков: " + ОписаниеОшибки());
	КонецПопытки;
	
КонецПроцедуры

&НаСервере
Функция ЗагрузитьОдинЧек(Чек)
	
	Попытка
		Если НЕ Метаданные.Документы.Содержит("АвансовыйОтчет") Тогда
			Сообщить("В конфигурации отсутствует документ АвансовыйОтчет.");
			Возврат Ложь;
		КонецЕсли;
		
		ДокументОбъект = Документы.АвансовыйОтчет.СоздатьДокумент();
		
		Если Чек.date <> Неопределено И НЕ ПустаяСтрока(Чек.date) Тогда
			ДокументОбъект.Дата = Дата(Чек.date);
		КонецЕсли;
		
		ИНН = "";
		Если Чек.inn <> Неопределено Тогда
			ИНН = Строка(Чек.inn);
		КонецЕсли;
		
		НаименованиеОрг = "";
		Если Чек.organization <> Неопределено Тогда
			НаименованиеОрг = Строка(Чек.organization);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ИНН) Тогда
			Контрагент = НайтиКонтрагентаПоИНН(ИНН, НаименованиеОрг);
			Если Контрагент <> Неопределено Тогда
				ДокументОбъект.Контрагент = Контрагент;
			КонецЕсли;
		КонецЕсли;
		
		Если Чек.total <> Неопределено Тогда
			ДокументОбъект.СуммаДокумента = Чек.total;
		КонецЕсли;
		
		Если Чек.items <> Неопределено Тогда
			Для Каждого Товар Из Чек.items Цикл
				СтрокаТЧ = ДокументОбъект.Товары.Добавить();
				
				НаимТовара = "";
				Если Товар.name <> Неопределено Тогда
					НаимТовара = Строка(Товар.name);
				КонецЕсли;
				Если ПустаяСтрока(НаимТовара) Тогда
					НаимТовара = "Товар без названия";
				КонецЕсли;
				
				СтрокаТЧ.Номенклатура = НайтиИлиСоздатьНоменклатуру(НаимТовара);
				СтрокаТЧ.Количество = ?(Товар.quantity = Неопределено, 1, Товар.quantity);
				СтрокаТЧ.Цена = ?(Товар.price = Неопределено, 0, Товар.price);
				СтрокаТЧ.Сумма = ?(Товар.amount = Неопределено, 0, Товар.amount);
				
				СтавкаСтрока = "";
				Если Товар.vat_rate <> Неопределено Тогда
					СтавкаСтрока = Строка(Товар.vat_rate);
				КонецЕсли;
				
				СтрокаТЧ.СтавкаНДС = НайтиСтавкуНДС(СтавкаСтрока);
				СтрокаТЧ.СуммаНДС = ?(Товар.vat_amount = Неопределено, 0, Товар.vat_amount);
			КонецЦикла;
		КонецЕсли;
		
		ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
		Возврат Истина;
		
	Исключение
		Сообщить("Ошибка загрузки чека: " + ОписаниеОшибки());
		Возврат Ложь;
	КонецПопытки;
	
КонецФункции

&НаСервере
Функция НайтиКонтрагентаПоИНН(ИНН, Наименование)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ Контрагенты.Ссылка
	               |ИЗ Справочник.Контрагенты КАК Контрагенты
	               |ГДЕ Контрагенты.ИНН = &ИНН";
	Запрос.УстановитьПараметр("ИНН", ИНН);
	Результат = Запрос.Выполнить().Выбрать();
	
	Если Результат.Следующий() Тогда
		Возврат Результат.Ссылка;
	КонецЕсли;
	
	НовыйКонтрагент = Справочники.Контрагенты.СоздатьЭлемент();
	НовыйКонтрагент.Наименование = ?(ПустаяСтрока(Наименование), "Контрагент " + ИНН, Наименование);
	НовыйКонтрагент.ИНН = ИНН;
	НовыйКонтрагент.Записать();
	Возврат НовыйКонтрагент.Ссылка;
	
КонецФункции

&НаСервере
Функция НайтиИлиСоздатьНоменклатуру(Наименование)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ Номенклатура.Ссылка
	               |ИЗ Справочник.Номенклатура КАК Номенклатура
	               |ГДЕ Номенклатура.Наименование = &Наим";
	Запрос.УстановитьПараметр("Наим", Наименование);
	Результат = Запрос.Выполнить().Выбрать();
	
	Если Результат.Следующий() Тогда
		Возврат Результат.Ссылка;
	КонецЕсли;
	
	НоваяНоменкл = Справочники.Номенклатура.СоздатьЭлемент();
	НоваяНоменкл.Наименование = Наименование;
	НоваяНоменкл.Записать();
	Возврат НоваяНоменкл.Ссылка;
	
КонецФункции

&НаСервере
Функция НайтиСтавкуНДС(СтавкаСтрока)
	
	Если СтавкаСтрока = "20%" Тогда
		Возврат Перечисления.СтавкиНДС.НДС20;
	ИначеЕсли СтавкаСтрока = "10%" Тогда
		Возврат Перечисления.СтавкиНДС.НДС10;
	ИначеЕсли СтавкаСтрока = "0%" Тогда
		Возврат Перечисления.СтавкиНДС.НДС0;
	Иначе
		Возврат Перечисления.СтавкиНДС.БезНДС;
	КонецЕсли;
	
КонецФункции
