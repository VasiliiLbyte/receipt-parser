// Тест: загрузка одного чека напрямую через HTTP
// Запускать в режиме 1С:Предприятие -> Инструменты -> Консоль кода

Процедура ТестЗагрузкиЧека()
    
    // --- Настройки (менять под свой сервер) ---
    СерверURL = "http://localhost:8000";
    UserID = 1;
    APIКлюч = "";  // пустой если API_KEY не задан в .env
    
    // --- HTTP запрос ---
    Попытка
        Соединение = Новый HTTPСоединение(
            "localhost",   // хост без http://
            8000,          // порт
            ,              // пользователь
            ,              // пароль
            ,              // прокси
            10,            // таймаут сек
            Новый ЗащищенноеСоединениеOpenSSL()  // убрать если http
        );
        
        Заголовки = Новый Соответствие;
        Заголовки["Accept"] = "application/json";
        Если APIКлюч <> "" Тогда
            Заголовки["X-API-Key"] = APIКлюч;
        КонецЕсли;
        
        Запрос = Новый HTTPЗапрос(
            "/api/v1/receipts?user_id=" + UserID,
            Заголовки
        );
        
        Ответ = Соединение.Получить(Запрос);
        
        Если Ответ.КодСостояния = 200 Тогда
            Сообщить("Успех! Статус: " + Ответ.КодСостояния);
            Сообщить("Тело ответа: " + Лев(Ответ.ПолучитьТелоКакСтроку(), 500));
        Иначе
            Сообщить("Ошибка HTTP: " + Ответ.КодСостояния);
        КонецЕсли;
        
    Исключение
        Сообщить("Исключение: " + ОписаниеОшибки());
    КонецПопытки;
    
КонецПроцедуры

ТестЗагрузкиЧека();
